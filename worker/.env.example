# --- LiveKit (worker connects to your LiveKit Cloud / self-hosted project) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Providers ---
# Fish Audio (TTS, s2.1-pro). FISH_VOICE_ID is a single MULTILINGUAL voice id
# used for every language — required for non-default voice.
FISH_API_KEY=
FISH_VOICE_ID=
# Fish TTS latency/quality: low | balanced | normal (low = snappiest first audio)
FISH_TTS_LATENCY_MODE=low

# OpenRouter (conversation LLM + qualification extraction side-call)
OPENROUTER_API_KEY=

# Deepgram (streaming STT)
DEEPGRAM_API_KEY=

# --- Model overrides (optional; sensible defaults baked in) ---
# Conversation LLM (OpenRouter notation). gpt-5/o-series get reasoning_effort=none.
LLM_PROVIDER=openrouter
LLM_MODEL=openai/gpt-5.4-mini
# Cheap/fast model for the JSON-mode qualification extraction side-call.
EXTRACTION_MODEL=openai/gpt-4.1-mini
EXTRACTION_MAX_TOKENS=300
# TTS / STT (leave STT_MODEL blank for Deepgram nova-3 default; STT_LANGUAGE is
# overridden per-session from dispatch metadata `language`).
TTS_PROVIDER=fish
TTS_MODEL=s2.1-pro
STT_PROVIDER=deepgram
STT_MODEL=

# --- Latency knobs ---
TURN_DETECTION_MODE=multilingual
PREEMPTIVE_GENERATION=true

# --- Local dev observability ---
LOG_LEVEL=INFO
LOG_FORMAT=console
OTEL_METRICS_EXPORTER=none

# Opener: say (canned localized line, lowest latency) | generate | none
GREETING_MODE=say
