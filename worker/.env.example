# --- LiveKit (worker connects to your LiveKit Cloud / self-hosted project) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Providers ---
# Fish Audio (TTS, s2.1-pro). FISH_VOICE_ID is a single MULTILINGUAL voice id
# used for every language — required for non-default voice.
FISH_API_KEY=
FISH_VOICE_ID=
# Fish TTS latency/quality: low | balanced | normal (low = snappiest first audio)
FISH_TTS_LATENCY_MODE=low

# OpenRouter (conversation LLM + qualification extraction side-call)
OPENROUTER_API_KEY=

# Deepgram (streaming STT)
DEEPGRAM_API_KEY=

# --- Conversation LLM ---
# Select the provider with LLM_PROVIDER:
#   custom     -> OpenAI-compatible endpoint (self-hosted Gemma/SGLang). Lowest-
#                 latency path: direct client, no OpenRouter proxy hop, no
#                 reasoning_effort. Configured by the CUSTOM_LLM_* vars below.
#   openrouter -> OpenRouter (50+ models; needs OPENROUTER_API_KEY above). gpt-5/
#                 o-series then get reasoning_effort=none. Model id = LLM_MODEL.
#   livekit    -> LiveKit Inference. Model id = LLM_MODEL.
LLM_PROVIDER=custom
# Generic model id for the openrouter / livekit providers (NOT used by 'custom').
LLM_MODEL=openai/gpt-5.4-mini

# Custom OpenAI-compatible endpoint (used when LLM_PROVIDER=custom). CUSTOM_LLM_MODEL
# is deliberately distinct from LLM_MODEL so the two never conflict.
CUSTOM_LLM_BASE_URL=https://sglang-fish-agent-gemma4-26b-a4b.dallas.api.fish.audio/v1
CUSTOM_LLM_MODEL=google/gemma-4-26B-A4B-it
CUSTOM_LLM_API_KEY=
# Hard cap on reply length (voice wants 1-2 short sentences); 0 = no cap.
CUSTOM_LLM_MAX_TOKENS=60
# Cheap/fast model for the JSON-mode qualification extraction side-call.
EXTRACTION_MODEL=openai/gpt-4.1-mini
EXTRACTION_MAX_TOKENS=300
# TTS / STT (leave STT_MODEL blank for Deepgram nova-3 default; STT_LANGUAGE is
# overridden per-session from dispatch metadata `language`).
TTS_PROVIDER=fish
TTS_MODEL=s2.1-pro
STT_PROVIDER=deepgram
STT_MODEL=

# --- Latency knobs ---
TURN_DETECTION_MODE=multilingual
PREEMPTIVE_GENERATION=true

# --- Local dev observability ---
LOG_LEVEL=INFO
LOG_FORMAT=console
OTEL_METRICS_EXPORTER=none

# Opener: say (canned localized line, lowest latency) | generate | none
GREETING_MODE=say
