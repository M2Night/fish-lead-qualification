# LiveKit server credentials (keys stay server-side; never shipped to the browser).
# Copy to `.env` and fill in. Values come from your LiveKit Cloud project or self-hosted server.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# Optional: HTTP port for this demo server (defaults to 3000).
PORT=3000
